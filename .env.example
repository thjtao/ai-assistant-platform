# ===================================
# AI Assistant Platform - 环境变量配置
# ===================================
# 复制此文件为 .env 并填写真实值

# --- 大模型 API Keys ---
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ZHIPU_API_KEY=your-zhipu-api-key  # 智谱开放平台 https://open.bigmodel.cn

# 默认使用的模型提供商: openai | anthropic | zhipu
LLM_PROVIDER=zhipu
LLM_MODEL=glm-4.7

# Embedding 模型
EMBEDDING_MODEL=text-embedding-3-small

# --- 数据库 ---
# 方式1: 直接设置完整连接串（优先）
# DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/ai_assistant

# 方式2: 拆分配置，从环境变量读取
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=ai_assistant

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT 安全 ---
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- 文件上传 ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# --- 向量数据库（Qdrant）---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=kb
CHROMA_PERSIST_DIR=./chroma_db

# --- 前端 ---
NEXT_PUBLIC_API_URL=http://localhost:8000
